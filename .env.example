# App
APP_NAME=crypto-wallet-intelligence
APP_VERSION=v0.1.0-dev
APP_ENV=development
APP_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
VITE_BACKEND_BASE_URL=http://127.0.0.1:8000

# Database
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=crypto_wallet_intelligence
POSTGRES_USER=cwi_app
POSTGRES_PASSWORD=change_me_do_not_commit_real_password
DATABASE_URL=postgresql+psycopg://cwi_app:change_me_do_not_commit_real_password@localhost:5432/crypto_wallet_intelligence

# Ollama
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# Paid model routing
PAID_MODEL_ESCALATION_ENABLED=true
PRIMARY_PAID_PROVIDER=openai
PRIMARY_DEVELOPMENT_MODEL=configure_cost_effective_openai_model
FALLBACK_PAID_PROVIDER=anthropic
FALLBACK_DEVELOPMENT_MODEL=configure_cost_effective_anthropic_model
PRODUCTION_REASONING_MODEL=configure_latest_suitable_model_when_system_is_in_use

# API keys - do not commit real values
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COINGECKO_API_KEY=
MORALIS_API_KEY=
ETHERSCAN_API_KEY=
ETHERSCAN_BASE_URL=https://api.etherscan.io/v2/api
ETHERSCAN_MAX_TRANSACTIONS_PER_WALLET=10
ETHERSCAN_TIMEOUT_SECONDS=15

# Security and feature flags
BROAD_MARKET_SEARCH_ENABLED=false
WHALE_WALLET_MONITORING_ENABLED=true
PATTERN_INTELLIGENCE_ENABLED=true
PAPER_TRADING_ENABLED=true
LIVE_TRADING_ENABLED=false
REQUIRE_MANUAL_APPROVAL_FOR_LIVE_TRADES=true
EMERGENCY_STOP_ENABLED=false
COPY_TRADE_CANDIDATE_ALERTS_ENABLED=true

# Candidate rules
MINIMUM_LIQUIDITY_USD_FOR_CANDIDATE=100000
MINIMUM_24H_VOLUME_USD_FOR_CANDIDATE=250000
MAXIMUM_ESTIMATED_SLIPPAGE_PERCENT=2.0
DEFAULT_COPY_TRADE_SCORE_THRESHOLD=70
DEFAULT_TOO_LATE_THRESHOLD=60
DEFAULT_DATA_QUALITY_THRESHOLD=75
DEFAULT_SOURCE_RELIABILITY_THRESHOLD=60
